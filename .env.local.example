# Optional read-only Firebase bridge. Do not commit the real service account file.
PARAWA_FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
PARAWA_FIREBASE_PROJECT_ID=mopi-af870
PARAWA_FIREBASE_STORAGE_BUCKET=mopi-af870.appspot.com
PARAWA_FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Optional comma-separated admin emails for Firebase Auth admin login.
PARAWA_ADMIN_EMAILS=admin@example.com

# Alternative deployment-friendly formats:
# PARAWA_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# PARAWA_FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
